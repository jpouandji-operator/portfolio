    })();

    // Scroll-triggered pull-quote animation - signature Teardowns element
    (function() {
      var pulls = document.querySelectorAll('.review-pull');
      if (!('IntersectionObserver' in window)) {
        pulls.forEach(function(p) { p.classList.add('in-view'); });
        return;
      }
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });
      pulls.forEach(function(p) { observer.observe(p); });
    })();
  </script>

