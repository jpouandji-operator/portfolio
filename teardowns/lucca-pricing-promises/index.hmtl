    (function() {
      var emailBtn = document.getElementById('email-btn');
      if (emailBtn) {
        emailBtn.onclick = function(e) {
          e.preventDefault();
          window.location.href = 'mailto:' + 'jpouandji' + '@' + 'gmail.com';
          if (typeof gtag !== 'undefined') { gtag('event', 'teardown_email_click'); }
          return false;
